int a(int arg1, int arg2){
    return arg1;
}

int b(int arg3, int arg4){
    return arg4;
}

int main(void){
    int res, alpha, beta;
    alpha = 5;
    beta = 9;

    res = a(beta - (alpha + a(beta, alpha)), beta % alpha);
    res = b(b(alpha) * res, res == alpha || res == beta);
    return 144;
}